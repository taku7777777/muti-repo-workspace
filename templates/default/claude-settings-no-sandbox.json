{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "env": {
    "OTEL_RESOURCE_ATTRIBUTES": "workspace={{TICKET_ID}},purpose={{PURPOSE}}"
  },

  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(mkdir *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.npmrc)",
      "Edit(/{{TASK_DIR}}/agents/**)",
      "Edit(/{{TASK_DIR}}/scripts/**)",
      "Edit(/{{WORKSPACE_ROOT}}/repositories/**)",
      "Edit(/{{WORKSPACE_ROOT}}/.claude/**)",
      "Edit(~/.claude.json)"
    ],
    "additionalDirectories": [
      "{{TASK_DIR}}",
      "{{WORKSPACE_ROOT}}/repositories"
    ]
  },

  "enabledMcpjsonServers": []
}
