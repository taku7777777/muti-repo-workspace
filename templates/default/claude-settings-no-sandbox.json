{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "env": {
    "OTEL_RESOURCE_ATTRIBUTES": "workspace={{TICKET_ID}},purpose={{PURPOSE}}"
  },

  "_security_note": "WARNING: without the OS sandbox, allowlisted shell tools can read files the Read-tool deny rules below block (e.g. `cat ~/.ssh/id_rsa`), and `find -exec` / `git difftool -x` would run arbitrary commands — so the allow list below deliberately excludes those escape hatches. No-sandbox mode gives tool-level guards only; it CANNOT fully protect secrets from shell reads. Use it only where the host is already trusted.",

  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(mkdir *)"
    ],
    "ask": [
      "Bash(find *)",
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.npmrc)",
      "Edit(/{{TASK_DIR}}/agents/**)",
      "Edit(/{{TASK_DIR}}/scripts/**)",
      "Edit(/{{WORKSPACE_ROOT}}/repositories/**)",
      "Edit(/{{WORKSPACE_ROOT}}/scripts/**)",
      "Edit(/{{WORKSPACE_ROOT}}/templates/**)",
      "Edit(/{{WORKSPACE_ROOT}}/config/**)",
      "Edit(/{{WORKSPACE_ROOT}}/.claude/**)",
      "Edit(~/.claude.json)"
    ],
    "additionalDirectories": [
      "{{TASK_DIR}}",
      "{{WORKSPACE_ROOT}}/repositories"
    ]
  },

  "enabledMcpjsonServers": []
}
