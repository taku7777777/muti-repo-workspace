# --- Workspace-generated content (never committed) ---

# Cloned target repositories (the workspace's "origins").
# The list of repositories lives in config/repos.json; the clones themselves
# are local state. Keeping them ignored also prevents git from treating the
# nested repositories as embedded repos / accidental submodules.
/repositories/*
!/repositories/.gitkeep

# Per-ticket task workspaces created by /open-task (worktrees, agent
# directories, generated settings). Purely local, disposable state.
/tasks/*
!/tasks/.gitkeep

# --- Generated by /setup-workspace (from templates/root/) ---
# The root sandbox settings are generated, not committed, so that simply
# cloning this repo for development does not lock the session into the
# operator sandbox. Run /setup-workspace to create it.
/.claude/settings.json
/.gitconfig-workspace

# --- Local overrides ---
# NB: deliberately NO config/workspace.local.json entry — no script reads such
# a file, and ignoring it would invite users to put allowed_push_orgs there
# and silently get unrestricted pushes (review Low-14).
.claude/settings.local.json

# --- Phase 0 dev container ---
# Runtime secret (ANTHROPIC_API_KEY) — injected at runtime, never committed.
# .env.example IS committed; the real .env is not.
.env
/.devcontainer/.env
# Harness build/runtime artifacts.
/harness/node_modules/
/harness/dist/

# --- Phase 2 publish broker ---
# Broker build/runtime artifacts and the runtime socket directory (created at
# `npm --prefix broker start`; bind-mounted into the coder read/write).
/broker/node_modules/
/broker/dist/
/.devcontainer/run-broker/

# --- M3 advisory reviewer ---
# Same reasoning as the broker above: build/runtime artifacts only, never the
# source (which IS committed — reviewer/src, reviewer/package.json, etc.).
/reviewer/node_modules/
/reviewer/dist/

# --- Thread B browser-approval serve ---
# Same reasoning again: build/runtime artifacts only, never the source
# (serve/src, serve/package.json etc. ARE committed).
/serve/node_modules/
/serve/dist/

# --- OS noise ---
.DS_Store
