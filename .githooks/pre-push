#!/usr/bin/env bash
# pre-push — restrict push destinations to the orgs listed in
# config/workspace.json (allowed_push_orgs).
#
# Installed by scripts/setup-workspace.sh for every repository and worktree
# under this workspace via `core.hooksPath` plus a `~/.gitconfig` includeIf
# scoped to the workspace directory. Because worktrees share the origin
# repo's config, this hook also applies inside tasks/<TICKET>/repositories/.
#
# git invokes pre-push with: $1 = remote name, $2 = remote URL.
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE_ROOT="$(dirname "$HOOK_DIR")"
# shellcheck source=../scripts/lib/common.sh
. "$WORKSPACE_ROOT/scripts/lib/common.sh"

# setup-workspace.sh bakes the canonical config directory into a gitdir-scoped
# include. Plain `git config --get` evaluates that includeIf (unlike
# `--global --get`), after local/worktree copies of the key are rejected as
# worker-writable tampering. This works even when state_root is outside the
# workspace ancestry. Command-line `-c` / GIT_CONFIG_* injection is owned by
# the operator launching push; workers cannot construct that push command.
# A walk-up remains only for legacy/re-setup compatibility.
# NOTE: the broker independently enforces allowed_push_orgs in-process from
# broker-policy.json (the authoritative gate on the container path); this
# hook is defence-in-depth for the native (non-containerized) push path.
_spoof_local="$(git config --local --get mrw.configDir 2>/dev/null || true)"
_spoof_worktree="$(git config --worktree --get mrw.configDir 2>/dev/null || true)"
if [ -n "$_spoof_local" ] || [ -n "$_spoof_worktree" ]; then
  echo "pre-push: BLOCKED: mrw.configDir found in repo-local/worktree git config (tampering — this key must only come from the setup-baked include file)." >&2
  exit 1
fi

_cfg_dir="$(git config --get mrw.configDir 2>/dev/null || true)"
if [ -n "$_cfg_dir" ]; then
  _cfg_source="baked"
  if ! _cfg_dir="$(canonicalize_path "$_cfg_dir")" || ! (reject_tasks_path "$_cfg_dir"); then
    echo "pre-push: BLOCKED: invalid setup-baked mrw.configDir." >&2
    exit 1
  fi
else
  _cfg_source="legacy"
  _d="$PWD"
  while [ "$_d" != "/" ]; do
  # SECURITY: skip any .mrw/ under a tasks/ segment (worker-writable state) —
  # a worker could commit .mrw/workspace.json into its own worktree to spoof
  # this allowlist. The legit workspace .mrw/ is a sibling of tasks/, above
  # it. MUST match scripts/lib/common.sh's config_dir() and cli/mrw.mjs.
  case "$_d" in
    */tasks|*/tasks/*) _d="$(dirname "$_d")"; continue ;;
  esac
    if [ -f "$_d/.mrw/workspace.json" ]; then
      _cfg_dir="$(canonicalize_path "$_d/.mrw")"
      reject_tasks_path "$_cfg_dir"
      _cfg_source="walkup"
      break
    fi
    _d="$(dirname "$_d")"
  done
fi
CONFIG_DIR="${_cfg_dir:-$(canonicalize_path "$WORKSPACE_ROOT/config")}"
CONFIG="$CONFIG_DIR/workspace.json"

REMOTE_URL="${2:-}"

# jq absence is an environment problem and remains fail-open for every source.
if ! command -v jq >/dev/null 2>&1; then
  echo "pre-push: WARNING: cannot read $CONFIG (jq not installed); allowing push." >&2
  exit 0
fi

if [ ! -f "$CONFIG" ]; then
  if [ "$_cfg_source" = "baked" ]; then
    echo "pre-push: BLOCKED: setup-baked config is missing $CONFIG." >&2
    exit 1
  fi
  echo "pre-push: WARNING: cannot read $CONFIG (missing file); allowing push." >&2
  exit 0
fi

if ! jq empty "$CONFIG" >/dev/null 2>&1; then
  echo "pre-push: BLOCKED: invalid JSON in $CONFIG." >&2
  exit 1
fi

ALLOWED_ORGS="$(jq -r '(.allowed_push_orgs // []) | join(" ")' "$CONFIG")"

# Extract host AND org/user from the remote URL.
#   git@github.com:ORG/repo.git | ssh://git@github.com/ORG/repo.git | https://github.com/ORG/repo.git
host=""
org=""
case "$REMOTE_URL" in
  *"://"*)
    host="$(printf '%s' "$REMOTE_URL" | sed -E 's#^[a-z+]+://([^/@]*@)?([^/:]+).*#\2#')"
    org="$(printf '%s' "$REMOTE_URL" | sed -E 's#^[a-z+]+://[^/]+/([^/]+)/.*#\1#')" ;;
  *@*:*/*)
    host="${REMOTE_URL#*@}" ; host="${host%%:*}"
    org="${REMOTE_URL#*:}" ; org="${org%%/*}" ;;
esac

if [ -z "$org" ] || [ "$org" = "$REMOTE_URL" ] || [ -z "$host" ]; then
  echo "pre-push: BLOCKED: cannot parse host/org from remote URL '$REMOTE_URL'." >&2
  exit 1
fi

# Host allowlist is enforced FIRST and ALWAYS — even when allowed_push_orgs is
# empty. Without it a redirected remote (e.g. a worker-written
# config.worktree remote.origin.url=https://evil.example/ALLOWED_ORG/repo, or
# simply an empty org policy) would exfiltrate. Defaults to github.com;
# override via config/workspace.json allowed_push_hosts.
ALLOWED_HOSTS="$(jq -r '(.allowed_push_hosts // ["github.com"]) | join(" ")' "$CONFIG")"
host_ok=false
for h in $ALLOWED_HOSTS; do
  [ "$host" = "$h" ] && host_ok=true
done
if ! $host_ok; then
  echo "pre-push: BLOCKED: push to host '$host' is not allowed (allowed: $ALLOWED_HOSTS)." >&2
  exit 1
fi

# Org allowlist: only skipped (with a warning) when unset, and only after the
# host check above has already run.
if [ -z "$ALLOWED_ORGS" ]; then
  echo "pre-push: WARNING: allowed_push_orgs is empty in config/workspace.json; push org is not restricted (host '$host' allowed)." >&2
  exit 0
fi

for allowed in $ALLOWED_ORGS; do
  if [ "$org" = "$allowed" ]; then
    exit 0
  fi
done

echo "pre-push: BLOCKED: push to org '$org' is not allowed (allowed: $ALLOWED_ORGS)." >&2
echo "pre-push: edit allowed_push_orgs in config/workspace.json to change this." >&2
exit 1
