# Broker environment (TRUSTED side only). Copy to broker/.env for a HOST-PROCESS
# run, or set these in .devcontainer/.env for the container deployment (default).
# NONE of these ever reach the coder container.
#
#   cp broker/.env.example broker/.env   # then edit
#
# Values land in the broker process/container env only. Use a short-lived,
# repo-scoped token and a real secrets store for production.

# --- REQUIRED ---------------------------------------------------------------

# Short-lived, repo-scoped GitHub token used ONLY for `git fetch`, `git push`, and
# `gh pr create`. It is stripped from every read-side command's env. Never put this
# in the coder's env or image.
BROKER_GITHUB_TOKEN=ghs_REPLACE_ME

# TRUSTED policy file (allowed_push_orgs / allowed_push_hosts / branch_prefix). The
# broker FAILS CLOSED if this is unset, unreadable, invalid, OR resolves inside the
# coder-writable worktrees/workspace tree. In the container image it is baked at
# /etc/mrw-broker/policy.json. For a host process, point it at a broker-owned path
# OUTSIDE the workspace, e.g. ~/.config/mrw-broker/policy.json.
BROKER_POLICY_FILE=/etc/mrw-broker/policy.json

# --- COMMON -----------------------------------------------------------------

# Base dir holding bare-named repo worktrees <dir>/<repo> (coder-writable, treated
# as untrusted). Point at tasks/<TICKET>/repositories for per-ticket work.
# Container default: /workspaces/muti-repo-workspace/repositories
# Host default:      <workspace>/repositories
#BROKER_WORKTREES_DIR=/workspaces/muti-repo-workspace/repositories

# The coder-writable tree the policy file must never live inside (F2 containment).
# Container: the mounted workspace path. Host: self-locates to the workspace root.
#BROKER_CODER_TREE=/workspaces/muti-repo-workspace

# Where the broker listens. Container default is inside the shared named volume.
# Host default: <workspace>/.devcontainer/run-broker/publish.sock
#BROKER_SOCKET_PATH=/run/broker/publish.sock

# --- OPTIONAL ---------------------------------------------------------------

# Separate budget (ms) for the human approval gate. 0 = unlimited (block forever).
# Does NOT bound the pre-request socket read (that has its own 30s timeout).
#BROKER_APPROVAL_TIMEOUT_MS=1800000

# Override the self-located workspace root (messaging + default coder tree).
#BROKER_WORKSPACE_ROOT=/workspaces/muti-repo-workspace
